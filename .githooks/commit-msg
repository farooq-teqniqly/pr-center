#!/bin/sh
#
# commit-msg hook: enforce Conventional Commits on the subject line.
# Format:  type(optional-scope)!: description
# Example: feat(client): add game log endpoint
#
msg_file="$1"

# First non-comment, non-blank line = the subject.
subject=$(grep -v '^#' "$msg_file" | sed '/^[[:space:]]*$/d' | head -n1)

# Let git-generated commits through (merge, revert, fixup!/squash! autosquash).
case "$subject" in
	"Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*)
		exit 0
		;;
esac

types='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
pattern="^(${types})(\([a-z0-9._-]+\))?!?: .+"

if printf '%s' "$subject" | grep -Eq "$pattern"; then
	exit 0
fi

echo "Aborting commit: subject does not follow Conventional Commits." >&2
echo "" >&2
echo "  Got:      $subject" >&2
echo "  Expected: <type>(<scope>)?<!>?: <description>   (scope and ! are optional)" >&2
echo "  Types:    feat fix docs style refactor perf test build ci chore revert" >&2
echo "  Examples: docs: document rate-limit handling" >&2
	echo "            feat(api): add review-requested search" >&2
	echo "            fix!: drop legacy last-seen marker format" >&2
exit 1
