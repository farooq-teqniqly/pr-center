#!/bin/sh
#
# pre-commit hook: enforce CSharpier formatting before a commit lands.
# Formatting is owned by CSharpier (local dotnet tool); this hook rejects a
# commit when any staged .cs file has formatting violations.
#
# Scoped to staged paths so unstaged files cannot block a commit. Limitation:
# CSharpier reads working-tree content, not the staged snapshot, so formatting
# a file after staging it lets the unformatted staged copy through -- re-stage
# after formatting.
#
# Skipped automatically when there are no .cs files staged.
#

staged_cs=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.cs$')

if [ -z "$staged_cs" ]; then
	exit 0
fi

if ! command -v dotnet >/dev/null 2>&1; then
	echo "pre-commit hook: 'dotnet' not found on PATH; skipping CSharpier check." >&2
	exit 0
fi

echo "pre-commit: running CSharpier check on staged .cs files..."
if ! printf '%s\n' "$staged_cs" | tr '\n' '\0' | xargs -0 dotnet csharpier check ; then
	echo "" >&2
	echo "Aborting commit: CSharpier found formatting violations." >&2
	echo "Run 'dotnet csharpier format .' to fix, then re-stage." >&2
	exit 1
fi

exit 0
