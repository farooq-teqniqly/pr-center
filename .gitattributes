# Normalize line endings: LF everywhere by default.
* text=auto eol=lf

# Windows-only files stay CRLF (mirror .editorconfig).
*.sln  text eol=crlf
*.slnx text eol=crlf
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary assets: never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.pdf  binary
